  "html": "<div class=\"fr-view\"><p><strong>Plain forms of various types of predicates</strong></p><table><tbody><tr><td colspan=\"2\" rowspan=\"2\"><br></td><td colspan=\"2\" rowspan=\"1\"><p><strong>positive</strong></p></td><td colspan=\"2\" rowspan=\"1\"><p><strong>negative</strong></p></td><td colspan=\"1\" rowspan=\"2\"><p><strong>てform</strong></p></td></tr><tr><td><p><strong>non-past</strong></p></td><td><p><strong>past</strong></p></td><td><p><strong>non-past</strong></p></td><td><p><strong>past</strong></p></td></tr><tr><td colspan=\"1\" rowspan=\"4\"><p><strong>verb</strong></p></td><td colspan=\"1\" rowspan=\"2\"><p><strong>group2</strong></p></td><td><p>たべます</p></td><td><p>たべました</p></td><td><p>たべません</p></td><td><p>たべませんでした</p></td><td><br></td></tr><tr><td><p>たべる</p></td><td><p>たべた</p></td><td><p>たべない</p></td><td><p>たべなかった</p></td><td><p>たべて</p></td></tr><tr><td colspan=\"1\" rowspan=\"2\"><p><strong>group1</strong></p></td><td><p>かいます</p></td><td><p>かいました</p></td><td><p>かいません</p></td><td><p>かいませんでした</p></td><td><br></td></tr><tr><td><p>かう</p></td><td><p>かった</p></td><td><p>かわない</p></td><td><p>かわなかった</p></td><td><p>かって</p></td></tr><tr><td colspan=\"2\" rowspan=\"4\"><p><strong>いadjective</strong></p></td><td><p>ながいです</p></td><td><p>ながかったです</p></td><td><p>ながくないです</p></td><td><p>ながくなかったです</p></td><td><br></td></tr><tr><td><p>ながい</p></td><td><p>ながかった</p></td><td><p>ながくない</p></td><td><p>ながくなかった</p></td><td><p>ながくて</p></td></tr><tr><td><p>いいです</p></td><td><p>よかったです</p></td><td><p>よくないです</p></td><td><p>よくなかったです</p></td><td><br></td></tr><tr><td><p>いい</p></td><td><p>よかった</p></td><td><p>よくない</p></td><td><p>よくなかった</p></td><td><p>よくて</p></td></tr><tr><td colspan=\"2\" rowspan=\"2\"><p><strong>なadjective</strong></p></td><td><p>しずかです</p></td><td><p>しずかでした</p></td><td><p>しずかじゃありません</p></td><td><pre>しずかじゃありませんでした</pre></td><td><br></td></tr><tr><td><p>しずかだ</p></td><td><p>しずかだった</p></td><td><p>しずかじゃない</p></td><td><p>しずかじゃ