  "html": "<div class=\"fr-view\"><h3>Day 9 Lesson 3 - Grammar Slides</h3><div id=\"viewer-gs_w02_d09_l03\" class=\"grammar-slide-viewer\"><img src=\"../../images/gs_w02_d09_l03_p01.jpg\" class=\"gs-page\" data-page=\"1\" style=\"display:block; max-width:100%; margin:0 auto;\" /><img src=\"../../images/gs_w02_d09_l03_p02.jpg\" class=\"gs-page\" data-page=\"2\" style=\"display:none; max-width:100%; margin:0 auto;\" /><div style=\"display:flex; gap:10px; align-items:center; justify-content:center; margin-top:12px;\"><button type=\"button\" class=\"gs-prev\">Prev</button><span class=\"gs-counter\">1 / 2</span><button type=\"button\" class=\"gs-next\">Next</button></div></div><div style=\"margin-top:14px; text-align:center;\"><audio controls preload=\"metadata\" src=\"../../audio/gs_w02_d09_l03.m4a\"></audio></div><script>(function(){  const root=document.getElementById('viewer-gs_w02_d09_l03');  if(!root){return;}  const pages=Array.from(root.querySelectorAll('.gs-page'));  if(!pages.length){return;}  const prev=root.querySelector('.gs-prev');  const next=root.querySelector('.gs-next');  const counter=root.querySelector('.gs-counter');  let idx=0;  function render(){    pages.forEach((p,i)=>{p.style.display = i===idx ? 'block' : 'none';});    counter.textContent = `${idx+1} / ${pages.length}`;    prev.disabled = idx===0;    next.disabled = idx===pages.length-1;  }  prev.addEventListener('click', ()=>{if(idx>0){idx-=1; render();}});  next.addEventListener('click', ()=>{if(idx<pages.length-1){idx+=1; render();}});  render();})();</script></div>",
