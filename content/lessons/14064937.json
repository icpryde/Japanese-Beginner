  "html": "<div class=\"fr-view\"><p><strong>Verbal forms review</strong></p><table><tbody><tr><td colspan=\"1\" rowspan=\"2\"><br></td><td><p><strong>ますform</strong></p></td><td><p><strong>Vたい</strong></p></td><td><p><strong>Vに(purpose)</strong></p></td><td><p><strong>てform</strong></p></td><td><p><strong>ないform</strong></p></td><td><p><strong>dictionary form</strong></p></td></tr><tr><td><p>D4</p></td><td><p>D19</p></td><td><p>D20</p></td><td><p>D25</p></td><td><p>D32</p></td><td><p>D22</p></td></tr><tr><td colspan=\"1\" rowspan=\"3\"><p><strong>group 2</strong></p></td><td><p>たべます</p></td><td><p>たべたい</p></td><td><p>たべに</p></td><td><p>たべて</p></td><td><p>たべない</p></td><td><p>たべる</p></td></tr><tr><td><p>みます</p></td><td><p>みたい</p></td><td><p>みに</p></td><td><p>みて</p></td><td><p>みない</p></td><td><p>みる</p></td></tr><tr><td><p>かります</p></td><td><p>かりたい</p></td><td><p>かりに</p></td><td><p>かりて</p></td><td><p>かりない</p></td><td><p>かりる</p></td></tr><tr><td colspan=\"1\" rowspan=\"2\"><p><strong>group 3</strong></p></td><td><p>します</p></td><td><p>したい</p></td><td><p>しに</p></td><td><p>して</p></td><td><p>しない</p></td><td><p>する</p></td></tr><tr><td><p>もってきます</p></td><td><p>もってきたい</p></td><td><p>&times;</p></td><td><p>もってきて</p></td><td><p>もってこない</p></td><td><p>もってくる</p></td></tr><tr><td colspan=\"1\" rowspan=\"9\"><p><strong>group1</strong></p></td><td><p>かします</p></td><td><p>かしたい</p></td><td><p>かしに</p></td><td><p>かして</p></td><td><p>かさない</p></td><td><p>かす</p></td></tr><tr><td><p>かきます</p></td><td><p>かきたい</p></td><td><p>かきに</p></td><td><p>かいて</p></td><td><p>かかない</p></td><td><p>かく</p></td></tr><tr><td><p>およぎます</p></td><td><p>およぎたい</p></td><td><p>およぎに</p></td><td><p>およいで</p></td><td><p>およがない</p></td><td><p>およぐ</p></td></tr><tr><td><p>よみます</p></td><td><p>よみたい</p></td><td><p>よみに</p></td><td><p>よんで</p></td><td><p>よまない</p></td><td><p>よむ</p></td></tr><tr><td><p>あそびます</p></td><td><p>あそびたい</p></td><td><p>あそびに</p></td><td><p>あそんで</p></td><td><p>あそばない</p></td><td><p>あそぶ</p></td></tr><t